{
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/audio_idle_inhibitor", "idle_inhibitor", "battery", "pulseaudio", "network", "tray"],
    "tray": {
        "spacing": 5
},
"battery": {
    "states": {
