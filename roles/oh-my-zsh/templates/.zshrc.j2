# DOTFILES
export DOTFILES_PATH="$HOME/.dotfiles/bin"

# PATH
export PATH="$DOTFILES_PATH:/usr/local/sbin:$PATH"

# SCRIPTS
export PATH="$PATH":"$HOME/.local/scripts/"

# OH-MY-ZSH
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="agnoster"

plugins=(git zsh-autosuggestions zsh-completions zsh-syntax-highlighting zsh-z send)

source $ZSH/oh-my-zsh.sh

# DEFAULTS
export ARCHFLAGS="-arch x86_64"
export EDITOR='nvim'



# The next line sources a private environment file if it exists
if [ -f "$HOME/.zsh_public" ]; then . "$HOME/.zsh_public"; fi
if [ -f "$HOME/.zsh_private" ]; then . "$HOME/.zsh_private"; fi

# KEYBINDINGS
set -o vi
bindkey -s ^f "tmux-sessionizer\n"
